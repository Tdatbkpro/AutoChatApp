<?xml version="1.0" encoding="utf-8"?>
<!--
    Background cho tvDescription trong fragment_article_detail.xml.
    Tạo thanh dọc bên trái (accent bar) kiểu blockquote.
    res/drawable/bg_description_bar.xml
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Nền nhẹ -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#141428" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <!-- Thanh accent bên trái 3dp -->
    <item android:right="99dp">
        <shape android:shape="rectangle">
            <solid android:color="#4A90E2" />
            <corners android:topLeftRadius="4dp" android:bottomLeftRadius="4dp" />
        </shape>
    </item>
</layer-list>