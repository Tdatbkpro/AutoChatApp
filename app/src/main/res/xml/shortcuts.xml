<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="voice_search"
        android:enabled="true"
        android:shortcutShortLabel="@string/shortcut_voice_short"
        android:shortcutLongLabel="@string/shortcut_voice_long">
        <intent
            android:action="android.intent.action.SEARCH"
            android:targetClass="com.example.autochat.ui.car.MyCarAppService"
            android:targetPackage="com.example.autochat">
            <extra
                android:name="query"
                android:key="query" />
        </intent>
    </shortcut>
</shortcuts>