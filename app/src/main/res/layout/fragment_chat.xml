<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/bgApp">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="?attr/bgSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:tint="?attr/iconColorSecondary"/>

        <LinearLayout
            android:id="@+id/btnModelStatus"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_model_status"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/ivModelIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_ai_model"
                app:tint="?attr/colorInfo"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvModelStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn model"
                android:textColor="?attr/textPrimary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_down"
                app:tint="?attr/iconColorSecondary"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSessionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chat mới"
            android:textColor="?attr/textPrimary"
            android:textSize="15sp"
            android:textStyle="normal"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="end"/>

        <ImageButton
            android:id="@+id/btnNewChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_add_message"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:tint="?attr/colorTeal"/>
    </LinearLayout>

    <!-- Audio Player Bar — ẩn mặc định -->
    <LinearLayout
        android:id="@+id/audioPlayerBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="?attr/colorPlayerBar"
        android:visibility="gone"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPlayerPlay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_circle_blue"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:contentDescription="Phát/Tạm dừng" />

        <TextView
            android:id="@+id/tvPlayerCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="?attr/colorPlayerText"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp" />

        <com.example.autochat.ui.phone.view.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:paddingVertical="2dp" />

        <TextView
            android:id="@+id/tvPlayerDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="?attr/colorPlayerText"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvPlayerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VieNeu TTS"
            android:textColor="?attr/textSecondary"
            android:textSize="11sp"
            android:maxWidth="64dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_label_chip"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnPlayerClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:background="?android:selectableItemBackgroundBorderless"
            android:alpha="0.7"
            android:contentDescription="Đóng"
            app:tint="?attr/iconColorSecondary" />
    </LinearLayout>

    <!-- Connection status bar -->
    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:background="?attr/bgCircleBlue"
        android:text="Đang kết nối lại..."
        android:textColor="?attr/colorInfo"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/audioPlayerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible"/>

    <!-- ProgressBar loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateTint="?attr/colorInfo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/typingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieTypingIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:lottie_fileName="lottie_typing.json"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"/>

        <TextView
            android:id="@+id/tvTyping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang nhập..."
            android:textColor="?attr/textSecondary"
            android:textSize="12sp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="always"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintTop_toBottomOf="@id/audioPlayerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="💬"
            android:textSize="48sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_dark"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có tin nhắn nào"
            android:textColor="?attr/textSecondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hãy bắt đầu trò chuyện với AI"
            android:textColor="?attr/textHint"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Skeleton Loading -->
    <LinearLayout
        android:id="@+id/skeletonLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_skeleton_circle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="80dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="220dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="160dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="220dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="160dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:layout_gravity="end">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <View
                    android:layout_width="180dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton_right"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="140dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton_right"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_skeleton_circle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="80dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="200dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="240dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="120dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Scroll to bottom button -->
    <ImageButton
        android:id="@+id/btnScrollToBottom"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_arrow_down"
        android:background="@drawable/bg_circle_blue"
        android:padding="10dp"
        android:visibility="gone"
        android:elevation="6dp"
        android:translationZ="6dp"
        app:tint="?attr/iconColorOnBrand"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        tools:visibility="visible" />

    <!-- ============================================================
         Input Layout — mic | endpoint pill | text field | toggle | send
         ============================================================ -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:background="?attr/bgApp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mic + Wave wrapper -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="6dp">

            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:background="@drawable/bg_circle_dark"
                android:elevation="2dp" />

            <com.example.autochat.ui.phone.view.MicWaveView
                android:id="@+id/micWaveView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="invisible"/>
        </FrameLayout>

        <!-- Endpoint Selector Pill Button -->
        <FrameLayout
            android:id="@+id/btnEndpoint"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_endpoint_pill"
            android:clickable="true"
            android:focusable="true"
            android:minWidth="0dp"
            android:gravity="center"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvEndpointOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingHorizontal="8dp"
                android:textColor="?attr/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:visibility="invisible"
                tools:text="NEWS"/>

            <TextView
                android:id="@+id/tvEndpointLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingHorizontal="8dp"
                android:text="NEWS"
                android:textColor="?attr/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </FrameLayout>

        <!-- Text Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMessage"
            style="@style/ChatInputStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập tin nhắn..."
                android:textColor="?attr/textPrimary"
                android:textColorHint="?attr/textHint2"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:imeOptions="actionSend"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:lineSpacingMultiplier="1.2"
                android:background="?attr/bgInput" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Toggle Online/Offline -->
        <ImageButton
            android:id="@+id/btnToggleMode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_offline"
            android:background="@drawable/bg_circle_dark"
            android:layout_marginEnd="8dp"
            android:elevation="2dp"
            android:visibility="gone"
            android:contentDescription="Chuyển chế độ Online/Offline"
            app:tint="?attr/colorSuccess" />

        <!-- Send/Pause button -->
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_circle_blue"
            android:elevation="2dp"
            android:alpha="0.4"
            android:enabled="false" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnShowUserMessages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Xem tin nhắn đã gửi"
        android:src="@drawable/ic_message_history"
        android:visibility="gone"
        app:backgroundTint="?attr/colorInfo"
        app:fabSize="normal"
        app:rippleColor="?attr/rippleColor"
        app:tint="?attr/iconColorOnBrand"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>