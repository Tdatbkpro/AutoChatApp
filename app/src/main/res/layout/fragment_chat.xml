<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#0A0A0F">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="#12121A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nút menu bên trái -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:tint="#AAAACC"/>

        <!-- Model status button ở giữa -->
        <LinearLayout
            android:id="@+id/btnModelStatus"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_model_status"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/ivModelIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_ai_model"
                app:tint="#4A90E2"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvModelStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn model"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_down"
                app:tint="#888899"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Nút chat mới + session title bên phải -->
        <TextView
            android:id="@+id/tvSessionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chat mới"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="normal"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="end"/>

        <ImageButton
            android:id="@+id/btnNewChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_add_message"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:tint="#31B1BD"/>
    </LinearLayout>

    <!-- Connection status bar -->
    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:background="#1A3A5C"
        android:text="Đang kết nối lại..."
        android:textColor="#4A90E2"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible"/>

    <!-- ProgressBar loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateTint="#4A90E2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/typingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieTypingIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:lottie_fileName="lottie_typing.json"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"/>

        <TextView
            android:id="@+id/tvTyping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang nhập..."
            android:textColor="#888899"
            android:textSize="12sp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="always"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="💬"
            android:textSize="48sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_dark"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có tin nhắn nào"
            android:textColor="#AAAACC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hãy bắt đầu trò chuyện với AI"
            android:textColor="#666"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Skeleton Loading -->
    <LinearLayout
        android:id="@+id/skeletonLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_skeleton_circle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="80dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="220dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="160dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:layout_gravity="end">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <View
                    android:layout_width="180dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton_right"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="140dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton_right"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_skeleton_circle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="80dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="200dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="240dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"
                    android:layout_marginBottom="6dp"/>

                <View
                    android:layout_width="120dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Scroll to bottom button -->
    <ImageButton
        android:id="@+id/btnScrollToBottom"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_arrow_down"
        android:background="@drawable/bg_circle_blue"
        android:padding="10dp"
        android:visibility="gone"
        android:elevation="6dp"
        android:translationZ="6dp"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        tools:visibility="visible" />

    <!-- Input Layout -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:background="#0D0D14"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mic button -->
        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/bg_circle_dark"
            android:layout_marginEnd="8dp"
            android:elevation="2dp" />

        <!-- Text Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMessage"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:boxStrokeWidth="1dp"
            app:boxStrokeColor="#2A2A3E"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxBackgroundColor="#1A1A2E"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập tin nhắn..."
                android:textColor="#FFFFFF"
                android:textColorHint="#555566"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:imeOptions="actionSend"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:lineSpacingMultiplier="1.2"
                android:background="@android:color/transparent" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ✅ THÊM: Toggle Online/Offline (chỉ hiện khi có model + có mạng) -->
        <ImageButton
            android:id="@+id/btnToggleMode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_offline"
            android:background="@drawable/bg_circle_dark"
            android:layout_marginEnd="8dp"
            android:elevation="2dp"
            android:visibility="gone"
            android:contentDescription="Chuyển chế độ Online/Offline"
            app:tint="#4CAF50" />

        <!-- Send/Pause button -->
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_circle_blue"
            android:elevation="2dp"
            android:alpha="0.4"
            android:enabled="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>