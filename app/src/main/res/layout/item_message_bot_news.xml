<?xml version="1.0" encoding="utf-8"?>
<!--
    Bot message dạng news list.
    Dùng bởi ChatMessageAdapter.BotNewsViewHolder (VIEW_TYPE_BOT_NEWS).
    Cấu trúc giống item_message_bot.xml nhưng thêm:
      - tvNewsCount   : badge "📰 N bài liên quan"
      - btnToggleNews : nút expand/collapse
      - newsListContainer : LinearLayout chứa các item_news_row
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="4dp"
    android:gravity="start">

    <!-- Bot avatar -->
    <TextView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="🤖"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Bubble chính -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E2E"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Summary text (full_response đã clean) -->
                <TextView
                    android:id="@+id/tvContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E0F0"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.3" />

                <!-- Badge số bài -->
                <TextView
                    android:id="@+id/tvNewsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_news_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="📰 0 bài liên quan"
                    android:textColor="#90CAF9"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <!-- Nút toggle expand/collapse -->
                <TextView
                    android:id="@+id/btnToggleNews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Xem danh sách ▼"
                    android:textColor="#64B5F6"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingVertical="4dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Container chứa các news row (ẩn mặc định) -->
                <LinearLayout
                    android:id="@+id/newsListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#60E0E0F0"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</LinearLayout>