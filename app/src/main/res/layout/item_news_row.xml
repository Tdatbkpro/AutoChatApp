<?xml version="1.0" encoding="utf-8"?>
<!--
    Một row bài báo bên trong newsListContainer của item_message_bot_news.xml.
    Được inflate thủ công bởi BotNewsViewHolder.populateNewsList().
    IDs cần khớp với code: tvNewsTitle, tvNewsDesc.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="4dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Số thứ tự + Tiêu đề: "1. Tên bài báo..." -->
    <TextView
        android:id="@+id/tvNewsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E0E0F0"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3" />

    <!-- Mô tả ngắn -->
    <TextView
        android:id="@+id/tvNewsDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="#9090B0"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3" />

    <!-- "Đọc chi tiết →" hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Đọc chi tiết →"
        android:textColor="#64B5F6"
        android:textSize="11sp" />

</LinearLayout>