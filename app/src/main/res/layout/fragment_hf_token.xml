<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#12121A"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_hf_logo"
                android:background="@drawable/bg_gradient"
                android:padding="10dp"
                app:tint="#FF9D00" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HuggingFace Token"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tăng tốc download lên 5-10x"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Token Status - ĐÃ SỬA MÀU CHỮ -->
    <LinearLayout
        android:id="@+id/layoutTokenStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp"
        android:background="#1E2A1E"
        android:padding="12dp"
        app:cardCornerRadius="12dp">

        <ImageView
            android:id="@+id/ivTokenStatusIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_circle"
            android:layout_marginEnd="10dp"
            app:tint="#4CAF50" />

        <TextView
            android:id="@+id/tvTokenStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chưa có token"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Input Token - ĐÃ SỬA MÀU HINT -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Nhập token hf_xxx..."
        app:hintTextColor="#6B7280"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="#4A90E2"
        app:boxStrokeWidth="2dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:startIconDrawable="@drawable/ic_key"
        app:startIconTint="#4A90E2"
        app:endIconMode="clear_text"
        app:endIconTint="#6B7280"
        app:boxBackgroundColor="#1A1A2E">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:inputType="textPassword"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:padding="14dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="💾 Lưu token"
            android:textColor="#FFFFFF"
            app:backgroundTint="#4A90E2"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestToken"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🧪"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#4A90E2"
            app:cornerRadius="24dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🗑️ Xóa token"
        android:textColor="#FF6B6B"
        android:visibility="gone"
        app:backgroundTint="#2A2A3E"
        app:cornerRadius="24dp"
        app:strokeColor="#FF6B6B"
        app:strokeWidth="1dp" />

    <!-- Security note -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:text="🔒 Token được lưu cục bộ, chỉ gửi đến HuggingFace"
        android:textColor="#6B7280"
        android:textSize="11sp" />

</LinearLayout>