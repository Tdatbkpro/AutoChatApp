<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm Model Tùy Chỉnh"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm model GGUF từ Repo"
        android:textColor="#888899"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />



    <!-- Mô tả -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mô tả (tùy chọn)"
        android:textColor="#AAAACC"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="#1A1A2E"
        app:boxStrokeColor="#2A2A40"
        app:shapeAppearance="@style/RoundedTextInput"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etModelDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="VD: Model tiếng Việt tùy chỉnh"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:padding="14dp"
            android:maxLines="2"
            android:background="@android:color/transparent" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- URL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Link repo (GGUF) trên huggingface hoặc hf-mirror"
        android:textColor="#AAAACC"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:boxBackgroundColor="#1A1A2E"
        app:boxStrokeColor="#2A2A40"
        app:shapeAppearance="@style/RoundedTextInput"
        app:hintEnabled="false"
        app:endIconMode="clear_text"
        app:endIconTint="#555566">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etModelUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://hf-mirror.com/.../...-GGUF"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:padding="14dp"
            android:inputType="textUri"
            android:maxLines="1"
            android:background="@android:color/transparent" />
    </com.google.android.material.textfield.TextInputLayout>
    <!-- Sau ô URL, thêm nút kiểm tra repo -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheckRepo"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Kiểm tra repo"
        android:textColor="#64B5F6"
        android:textSize="12sp"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="#2A2A40"
        app:strokeWidth="1dp"
        app:cornerRadius="18dp"
        android:layout_marginBottom="8dp" />

    <!-- File đã chọn -->
    <!-- File đã chọn + nút x -->
    <LinearLayout
        android:id="@+id/layoutSelectedFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectedFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#4CAF50"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnClearSelection"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textColor="#FF6B6B"
            android:textSize="14sp"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
    <ProgressBar
        android:id="@+id/progressChecking"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        android:indeterminateTint="#64B5F6" />
    <!-- Danh sách file GGUF -->
    <LinearLayout
        android:id="@+id/layoutFileList"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn phiên bản:"
            android:textColor="#AAAACC"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFileList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>
    <!-- Thông tin thiết bị -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="#15152A"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📱 Thiết bị của bạn"
            android:textColor="#888899"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvDeviceInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAM: 4GB | Android 14"
            android:textColor="#64B5F6"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Cảnh báo -->
    <LinearLayout
        android:id="@+id/layoutWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#1A1A00"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚠️ Model lớn hơn RAM khả dụng, có thể crash!"
            android:textColor="#FF9800"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Hủy"
            android:textColor="#AAAACC"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="22dp"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Thêm model"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6C63FF"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_add"
            app:iconSize="18dp" />
    </LinearLayout>

</LinearLayout>