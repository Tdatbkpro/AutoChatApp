<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/bottom_sheet_edit_message.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:clipToOutline="true">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✎  Chỉnh sửa tin nhắn"
            android:textColor="#C9D1D9"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <!-- Branch badge -->
        <TextView
            android:id="@+id/tvBranchBadge"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="+ Nhánh mới"
            android:textColor="#BC8CFF"
            android:textSize="11sp"
            android:background="@drawable/bg_meta_chip_purple"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#21262D"
        android:layout_marginHorizontal="18dp"/>

    <!-- Original message preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tin nhắn gốc"
            android:textColor="#484F58"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvOriginalMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stdin_field"
            android:textColor="#6E7681"
            android:textSize="13sp"
            android:padding="12dp"
            android:maxLines="3"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Edit field -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nội dung mới"
            android:textColor="#484F58"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etEditContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@drawable/bg_edit_field"
            android:textColor="#E6EDF3"
            android:textSize="14sp"
            android:padding="14dp"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:lineSpacingMultiplier="1.4"
            android:hint="Nhập nội dung mới..."
            android:textColorHint="#30363D"/>

        <!-- Char counter -->
        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="0"
            android:textColor="#484F58"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Send button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:gravity="end">

        <!-- Cancel -->
        <TextView
            android:id="@+id/btnCancelEdit"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="Hủy"
            android:textColor="#8B949E"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Send -->
        <LinearLayout
            android:id="@+id/btnSendEdit"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/bg_run_btn_solid"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp">

            <ProgressBar
                android:id="@+id/progressEdit"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:indeterminateTint="#0D1117"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvSendEditLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gửi  ▶"
                android:textColor="#0D1117"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>