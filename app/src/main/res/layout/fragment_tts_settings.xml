<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/bgSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp" android:layout_height="4dp"
            android:layout_gravity="center_horizontal" android:layout_marginTop="12dp"
            android:background="?attr/strokeDefault"/>

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingHorizontal="20dp" android:paddingTop="14dp" android:paddingBottom="12dp">
            <TextView android:text="🔊" android:textSize="22sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"/>
            <TextView android:text="Cài đặt TTS"
                android:textColor="?attr/textPrimary" android:textSize="17sp" android:textStyle="bold"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <TextView android:text="v2.0"
                android:textColor="?attr/colorTeal" android:textSize="10sp" android:textStyle="bold"
                android:background="@drawable/bg_badge_teal"
                android:paddingHorizontal="7dp" android:paddingVertical="2dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/strokeDefault"/>

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="16dp">

            <!-- ENGINE -->
            <TextView android:text="ENGINE"
                android:textColor="?attr/textHint2" android:textSize="11sp" android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <GridLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:columnCount="2" android:rowCount="2"
                android:layout_marginBottom="16dp">

                <LinearLayout android:id="@+id/cardGoogle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_marginEnd="4dp" android:layout_marginBottom="8dp"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_engine_card" android:padding="12dp"
                    android:clickable="true" android:focusable="true">
                    <TextView android:text="🌐" android:textSize="22sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Google TTS"
                        android:textColor="?attr/textSecondary" android:textSize="12sp" android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Online"
                        android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:background="?attr/bgApp"
                        android:paddingHorizontal="5dp" android:paddingVertical="1dp"
                        android:layout_marginTop="3dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cardVieNeu"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_marginStart="4dp" android:layout_marginBottom="8dp"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_engine_card_active" android:padding="12dp"
                    android:clickable="true" android:focusable="true">
                    <TextView android:text="🦜" android:textSize="22sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="VieNeu TTS"
                        android:textColor="?attr/colorTeal" android:textSize="12sp" android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="On-device"
                        android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:background="?attr/bgApp"
                        android:paddingHorizontal="5dp" android:paddingVertical="1dp"
                        android:layout_marginTop="3dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cardEdge"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_marginEnd="4dp"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_engine_card" android:padding="12dp"
                    android:clickable="true" android:focusable="true">
                    <TextView android:text="🪟" android:textSize="22sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Microsoft Edge"
                        android:textColor="?attr/textSecondary" android:textSize="12sp" android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Offline"
                        android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:background="?attr/bgApp"
                        android:paddingHorizontal="5dp" android:paddingVertical="1dp"
                        android:layout_marginTop="3dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cardSystem"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_marginStart="4dp"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_engine_card" android:padding="12dp"
                    android:clickable="true" android:focusable="true">
                    <TextView android:text="📱" android:textSize="22sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="System TTS"
                        android:textColor="?attr/textSecondary" android:textSize="12sp" android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Offline"
                        android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:background="?attr/bgApp"
                        android:paddingHorizontal="5dp" android:paddingVertical="1dp"
                        android:layout_marginTop="3dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </GridLayout>

            <!-- SLIDERS -->
            <TextView android:text="ĐIỀU CHỈNH GIỌNG"
                android:textColor="?attr/textHint2" android:textSize="11sp" android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card" android:padding="14dp"
                android:layout_marginBottom="16dp">

                <!-- Pitch -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:text="🎵 Cao độ (Pitch)"
                        android:textColor="?attr/textSecondary" android:textSize="12sp" android:textStyle="bold"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvPitchValue" android:text="0"
                        android:textColor="?attr/colorTeal" android:textSize="12sp" android:textStyle="bold"
                        android:background="@drawable/bg_badge_teal"
                        android:paddingHorizontal="8dp" android:paddingVertical="2dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekPitch"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="20" android:progress="10"
                    android:progressTint="?attr/colorTeal" android:thumbTint="?attr/colorTeal"
                    android:layout_marginBottom="2dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="14dp">
                    <TextView android:text="Thấp" android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="Bình thường" android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Cao" android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Speed -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:text="⚡ Tốc độ (Speed)"
                        android:textColor="?attr/textSecondary" android:textSize="12sp" android:textStyle="bold"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvSpeedValue" android:text="1.0x"
                        android:textColor="?attr/colorTeal" android:textSize="12sp" android:textStyle="bold"
                        android:background="@drawable/bg_badge_teal"
                        android:paddingHorizontal="8dp" android:paddingVertical="2dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekSpeed"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="30" android:progress="10"
                    android:progressTint="?attr/colorTeal" android:thumbTint="?attr/colorTeal"
                    android:layout_marginBottom="2dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="14dp">
                    <TextView android:text="0.5x" android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="1.0x" android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="2.0x" android:textColor="?attr/textHint2" android:textSize="9sp"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Volume -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:text="🔊 Âm lượng"
                        android:textColor="?attr/textSecondary" android:textSize="12sp" android:textStyle="bold"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvVolumeValue" android:text="100%"
                        android:textColor="?attr/colorTeal" android:textSize="12sp" android:textStyle="bold"
                        android:background="@drawable/bg_badge_teal"
                        android:paddingHorizontal="8dp" android:paddingVertical="2dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekVolume"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="100"
                    android:progressTint="?attr/colorTeal" android:thumbTint="?attr/colorTeal"/>
            </LinearLayout>

            <!-- VIENEU SETTINGS -->
            <LinearLayout android:id="@+id/layoutVieNeuSettings"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:text="GIỌNG VIENEU"
                    android:textColor="?attr/textHint2" android:textSize="11sp" android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Mode tabs -->
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_tab_container"
                    android:padding="3dp" android:layout_marginBottom="10dp">
                    <TextView android:id="@+id/tabPreset" android:text="🎭  Giọng có sẵn"
                        android:textColor="?attr/colorTeal" android:textSize="12sp" android:textStyle="bold"
                        android:gravity="center" android:background="@drawable/bg_tab_active"
                        android:paddingVertical="7dp"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tabClone" android:text="🎙️  Clone giọng"
                        android:textColor="?attr/textHint2" android:textSize="12sp" android:textStyle="bold"
                        android:gravity="center" android:paddingVertical="7dp"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>

                <!-- Preset voices -->
                <LinearLayout android:id="@+id/layoutPresetVoice"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="16dp">
                    <TextView android:id="@+id/tvVoicesLoading"
                        android:text="Đang tải danh sách giọng..."
                        android:textColor="?attr/textHint" android:textSize="12sp" android:visibility="gone"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPresetVoices"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>

                <!-- Clone settings -->
                <LinearLayout android:id="@+id/layoutCloneVoice"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card" android:padding="14dp">

                        <TextView android:text="Tên giọng"
                            android:textColor="?attr/textSecondary" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"/>
                        <EditText android:id="@+id/etVoiceName"
                            android:hint="vd: Giọng của Mẹ, Giọng Sếp..."
                            android:textColor="?attr/textPrimary" android:textColorHint="?attr/textHint2"
                            android:background="@drawable/bg_input" android:padding="10dp"
                            android:textSize="13sp" android:inputType="text"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"/>

                        <TextView android:text="Audio mẫu (3-5 giây)"
                            android:textColor="?attr/textSecondary" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:background="@drawable/bg_input" android:padding="10dp"
                            android:layout_marginBottom="10dp">
                            <TextView android:text="🎵" android:textSize="16sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvRefAudioName" android:text="Chưa chọn file"
                                android:textColor="?attr/textHint" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:ellipsize="end" android:singleLine="true"/>
                        </LinearLayout>

                        <!-- Record / Pick buttons -->
                        <GridLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:columnCount="2" android:layout_marginBottom="10dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRecord"
                                android:text="🎙️  Ghi âm"
                                android:textColor="?attr/textSecondary" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_marginEnd="4dp" android:layout_marginBottom="8dp"
                                app:strokeColor="?attr/strokeDefault" app:strokeWidth="1.5dp"
                                app:backgroundTint="?attr/bgApp"
                                android:insetTop="0dp" android:insetBottom="0dp"
                                app:cornerRadius="10dp"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickRefAudio"
                                android:text="📁  Chọn file"
                                android:textColor="?attr/textSecondary" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_columnWeight="1"
                                android:layout_marginStart="4dp" android:layout_marginBottom="8dp"
                                app:strokeColor="?attr/strokeDefault" app:strokeWidth="1.5dp"
                                app:backgroundTint="?attr/bgApp"
                                android:insetTop="0dp" android:insetBottom="0dp"
                                app:cornerRadius="10dp"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPlayRecord"
                                android:text="▶  Nghe lại"
                                android:textColor="?attr/colorBrand" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_columnWeight="1" android:layout_marginEnd="4dp"
                                app:strokeColor="?attr/strokeBlue" app:strokeWidth="1.5dp"
                                app:backgroundTint="?attr/bgButton"
                                android:insetTop="0dp" android:insetBottom="0dp"
                                app:cornerRadius="10dp"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDeleteRecord"
                                android:text="🗑  Xóa"
                                android:textColor="?attr/colorDanger" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_columnWeight="1" android:layout_marginStart="4dp"
                                app:strokeColor="?attr/strokeDanger" app:strokeWidth="1.5dp"
                                app:backgroundTint="?attr/bgDanger"
                                android:insetTop="0dp" android:insetBottom="0dp"
                                app:cornerRadius="10dp"/>
                        </GridLayout>

                        <!-- Recording status -->
                        <LinearLayout android:id="@+id/layoutRecording"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:background="@drawable/bg_input" android:padding="10dp"
                            android:layout_marginBottom="10dp" android:visibility="gone">
                            <View android:id="@+id/viewRecordDot"
                                android:layout_width="10dp" android:layout_height="10dp"
                                android:background="@drawable/bg_circle_red"
                                android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvRecordTimer"
                                android:text="00:00 / 00:10"
                                android:textColor="?attr/colorDanger" android:textSize="13sp" android:textStyle="bold"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStopRecord"
                                android:text="⏹ Dừng"
                                android:textSize="12sp" android:textColor="?attr/bgSurface"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                app:backgroundTint="?attr/colorDanger"
                                android:insetTop="0dp" android:insetBottom="0dp"
                                app:cornerRadius="8dp"/>
                        </LinearLayout>

                        <!-- Preview row -->
                        <LinearLayout android:id="@+id/layoutRecordPreview"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:background="@drawable/bg_input" android:padding="10dp"
                            android:layout_marginBottom="10dp" android:visibility="gone">
                            <TextView android:id="@+id/tvRecordedFileName"
                                android:textColor="?attr/colorBrand" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:ellipsize="end" android:singleLine="true"/>
                        </LinearLayout>

                        <TextView android:text="Transcript audio mẫu"
                            android:textColor="?attr/textSecondary" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"/>
                        <EditText android:id="@+id/etRefText"
                            android:hint="Nội dung đã nói trong audio mẫu..."
                            android:textColor="?attr/textPrimary" android:textColorHint="?attr/textHint2"
                            android:background="@drawable/bg_input" android:padding="10dp"
                            android:maxLines="3" android:inputType="textMultiLine"
                            android:textSize="12sp"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- BUTTONS -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="?attr/strokeDefault" android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestTts"
                android:text="▶  Test giọng"
                android:textColor="?attr/colorBrand" android:textSize="14sp" android:textStyle="bold"
                android:layout_width="match_parent" android:layout_height="48dp"
                app:backgroundTint="?attr/bgButton"
                android:insetTop="0dp" android:insetBottom="0dp"
                app:cornerRadius="12dp" android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveTts"
                android:text="💾  Lưu cài đặt"
                android:textColor="?attr/bgSurface" android:textSize="14sp" android:textStyle="bold"
                android:layout_width="match_parent" android:layout_height="48dp"
                app:backgroundTint="?attr/colorTeal"
                android:insetTop="0dp" android:insetBottom="0dp"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>